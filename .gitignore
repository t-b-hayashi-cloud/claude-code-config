# ============================================================================
# Claude Code Configuration - Public Repository .gitignore
# ============================================================================
# STRATEGY: すべてを拒否し、安全なディレクトリのみを明示的に許可
# ============================================================================

# すべてをデフォルトで拒否
*
!*/

# ============================================================================
# 明示的に許可: 公開設定ディレクトリ
# ============================================================================

# エージェント定義
!agents/
!agents/**/*.md

# ルールとガイドライン
!rules/
!rules/**/*.md

# スキルドキュメント
!skills/
!skills/**/
!skills/**/SKILL.md

# ============================================================================
# 明示的に許可: リポジトリメタデータ
# ============================================================================
!.gitignore
!README.md
!LICENSE

# ============================================================================
# 重要: 機密ファイルを常に除外（公開ディレクトリ内でも）
# ============================================================================

# 認証情報とシークレット
.credentials.json
*.credentials.json
**/.credentials.json

# セッションと履歴データ
history.jsonl
*.history.jsonl
**/*.history.jsonl
sessions.json
*.sessions.json

# キャッシュと統計
stats-cache.json
**/stats-cache.json
*-cache.json
**/*-cache.json

# 環境変数とシークレット
.env
.env.*
**/.env
**/.env.*
*.key
*.pem
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml

# プライベートキーと証明書
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.private
*.secret

# APIトークンとOAuth
token.json
oauth*.json
access_token*
refresh_token*

# バックアップファイル
*.backup
*.bak
*.old
*.orig
*~

# 一時ファイル
*.tmp
*.temp
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================================
# ブロック: プライベートディレクトリ（冗長的な保護層）
# ============================================================================
projects/
sessions/
debug/
tasks/
plans/
file-history/
backups/
session-env/
paste-cache/
todos/
telemetry/
homunculus/
ide/
metrics/
cache/
downloads/
shell-snapshots/
plugins/

# ============================================================================
# ブロック: ビルドとパッケージファイル
# ============================================================================
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
ENV/
env/

# ============================================================================
# ブロック: IDEとエディタファイル
# ============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.vs/
